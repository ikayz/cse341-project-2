# MongoDB connection string for local development
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database-name>?retryWrites=true&w=majority

# Optional local port override
PORT=3000

# Session secret used to sign login cookies
SESSION_SECRET=replace-with-a-long-random-string

# Optional: use MongoDB for session storage instead of the default in-memory store
SESSION_STORE=mongo

# GitHub OAuth credentials
# Local callback: http://localhost:3000/auth/github/callback
# Render callback: https://your-render-app.onrender.com/auth/github/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback
