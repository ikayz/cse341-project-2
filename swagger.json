{
  "openapi": "3.0.0",
  "info": {
    "title": "Zambia Voters API",
    "version": "1.0.0",
    "description": "CRUD API for voter registration data with validation and error handling."
  },
  "servers": [
    {
      "url": "/",
      "description": "Current server"
    }
  ],
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "connect.sid",
        "description": "Session cookie created after logging in with GitHub OAuth at /auth/github."
      },
      "githubOAuth": {
        "type": "oauth2",
        "description": "GitHub OAuth login is handled through /auth/github and stores the authenticated session in a secure cookie.",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://github.com/login/oauth/authorize",
            "tokenUrl": "https://github.com/login/oauth/access_token",
            "scopes": {
              "user:email": "Read the user's GitHub email addresses"
            }
          }
        }
      }
    },
    "schemas": {
      "VoterCreate": {
        "type": "object",
        "properties": {
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "nationalID": { "type": "string" },
          "dateOfBirth": { "type": "string", "format": "date" },
          "gender": { "type": "string", "enum": ["male", "female", "other"] },
          "province": { "type": "string" },
          "constituency": { "type": "string" },
          "ward": { "type": "string" },
          "pollingStation": { "type": "string" }
        },
        "required": [
          "firstName",
          "lastName",
          "nationalID",
          "dateOfBirth",
          "gender",
          "province",
          "constituency",
          "ward",
          "pollingStation"
        ]
      },
      "Voter": {
        "allOf": [
          { "$ref": "#/components/schemas/VoterCreate" },
          {
            "type": "object",
            "properties": {
              "_id": { "type": "string", "readOnly": true }
            }
          }
        ]
      },
      "PollingStationCreate": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "province": { "type": "string" },
          "constituency": { "type": "string" },
          "ward": { "type": "string" },
          "address": { "type": "string" }
        },
        "required": ["name", "province", "constituency", "ward", "address"]
      },
      "PollingStation": {
        "allOf": [
          { "$ref": "#/components/schemas/PollingStationCreate" },
          {
            "type": "object",
            "properties": {
              "_id": { "type": "string", "readOnly": true }
            }
          }
        ]
      },
      "ErrorResponse": {
        "allOf": [
          { "$ref": "#/components/schemas/VoterCreate" },
          {
            "type": "object",
            "properties": {
              "_id": { "type": "string", "readOnly": true }
            }
          }
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": { "error": { "type": "string" } }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "displayName": { "type": "string" },
          "username": { "type": "string" },
          "email": { "type": "string" },
          "photo": { "type": "string" },
          "provider": { "type": "string", "example": "github" }
        }
      },
      "AuthStatus": {
        "type": "object",
        "properties": {
          "authenticated": { "type": "boolean" },
          "user": {
            "oneOf": [
              { "$ref": "#/components/schemas/User" },
              { "type": "null" }
            ]
          }
        }
      }
    }
  },
  "paths": {
    "/auth/github": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Start GitHub OAuth login",
        "description": "Redirects the browser to GitHub. On first successful login, the API creates a user account from the GitHub profile.",
        "responses": {
          "302": { "description": "Redirect to GitHub OAuth authorization screen" },
          "503": { "description": "GitHub OAuth environment variables are not configured" }
        }
      }
    },
    "/auth/github/callback": {
      "get": {
        "tags": ["Authentication"],
        "summary": "GitHub OAuth callback",
        "description": "GitHub redirects here after login. A successful callback creates an authenticated session cookie.",
        "responses": {
          "302": { "description": "Redirect to authenticated profile or login failure route" },
          "503": { "description": "GitHub OAuth environment variables are not configured" }
        }
      }
    },
    "/auth/status": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Check current login status",
        "responses": {
          "200": {
            "description": "Authentication status",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthStatus" }
              }
            }
          }
        }
      }
    },
    "/auth/profile": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Get the logged-in user's profile",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Authenticated user profile",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "401": { "description": "Authentication required" }
        }
      }
    },
    "/auth/logout": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Log out the current user",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "description": "Logout confirmation" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/api/voters": {
      "get": {
        "tags": ["Voters"],
        "summary": "Get all voters",
        "responses": {
          "200": {
            "description": "A list of voters",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Voter" }
                },
                "examples": {
                  "sampleList": {
                    "summary": "A sample voter list",
                    "value": [
                      {
                        "firstName": "Isaac",
                        "lastName": "Miti",
                        "nationalID": "1234567890123456",
                        "dateOfBirth": "1990-07-12",
                        "gender": "male",
                        "province": "Lusaka",
                        "constituency": "Lusaka Central",
                        "ward": "Kabwa",
                        "pollingStation": "St. Mary's School"
                      }
                    ]
                  }
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Voters"],
        "summary": "Create a new voter",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/VoterCreate" },
              "example": {
                "firstName": "Isaac",
                "lastName": "Miti",
                "nationalID": "1234567890123456",
                "dateOfBirth": "1990-07-12",
                "gender": "male",
                "province": "Lusaka",
                "constituency": "Lusaka Central",
                "ward": "Kabwa",
                "pollingStation": "St. Mary's School"
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Voter created" },
          "400": { "description": "Validation error" },
          "401": { "description": "Authentication required" },
          "409": { "description": "Duplicate nationalID" }
        }
      }
    },
    "/api/pollingStations": {
      "get": {
        "tags": ["PollingStations"],
        "summary": "Get all polling stations",
        "responses": {
          "200": {
            "description": "A list of polling stations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/PollingStation" }
                },
                "examples": {
                  "sampleList": {
                    "summary": "A sample polling station list",
                    "value": [
                      {
                        "name": "Center Station A",
                        "province": "Lusaka",
                        "constituency": "Lusaka Central",
                        "ward": "Kabwe",
                        "address": "123 Market Road"
                      }
                    ]
                  }
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["PollingStations"],
        "summary": "Create a new polling station",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PollingStationCreate" },
              "example": {
                "name": "Center Station A",
                "province": "Lusaka",
                "constituency": "Lusaka Central",
                "ward": "Kabwe",
                "address": "123 Market Road"
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Polling station created" },
          "400": { "description": "Validation error" },
          "401": { "description": "Authentication required" }
        }
      }
    },
    "/api/pollingStations/{id}": {
      "get": {
        "tags": ["PollingStations"],
        "summary": "Get a polling station by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "6472c1f9b2ef2b7a6f8d3a54"
          }
        ],
        "responses": {
          "200": {
            "description": "Polling station data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PollingStation" },
                "example": {
                  "name": "Center Station A",
                  "province": "Lusaka",
                  "constituency": "Lusaka Central",
                  "ward": "Kabwe",
                  "address": "123 Market Road"
                }
              }
            }
          },
          "400": { "description": "Invalid ID" },
          "404": { "description": "Polling station not found" }
        }
      },
      "put": {
        "tags": ["PollingStations"],
        "summary": "Update a polling station by ID",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "6472c1f9b2ef2b7a6f8d3a54"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "province": { "type": "string" },
                  "constituency": { "type": "string" },
                  "ward": { "type": "string" },
                  "address": { "type": "string" }
                }
              },
              "example": {
                "name": "Center Station B",
                "province": "Copperbelt",
                "constituency": "Ndola Central",
                "ward": "Mayeni",
                "address": "456 Civic Road"
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated polling station" },
          "400": { "description": "Validation error or invalid ID" },
          "401": { "description": "Authentication required" },
          "404": { "description": "Polling station not found" }
        }
      },
      "delete": {
        "tags": ["PollingStations"],
        "summary": "Delete a polling station by ID",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "6472c1f9b2ef2b7a6f8d3a54"
          }
        ],
        "responses": {
          "200": { "description": "Delete confirmation" },
          "400": { "description": "Invalid ID" },
          "401": { "description": "Authentication required" },
          "404": { "description": "Polling station not found" }
        }
      }
    },
    "/api/voters/{id}": {
      "get": {
        "tags": ["Voters"],
        "summary": "Get a voter by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "6472c1f9b2ef2b7a6f8d3a54"
          }
        ],
        "responses": {
          "200": {
            "description": "Voter data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Voter" },
                "example": {
                  "firstName": "Zaina",
                  "lastName": "Phiri",
                  "nationalID": "2345678901234567",
                  "dateOfBirth": "1984-05-21",
                  "gender": "female",
                  "province": "Copperbelt",
                  "constituency": "Ndola Central",
                  "ward": "Mayeni",
                  "pollingStation": "Ndola Civic Center"
                }
              }
            }
          },
          "400": { "description": "Invalid ID" },
          "404": { "description": "Voter not found" }
        }
      },
      "put": {
        "tags": ["Voters"],
        "summary": "Update a voter by ID",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "6472c1f9b2ef2b7a6f8d3a54"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "province": { "type": "string" },
                  "ward": { "type": "string" },
                  "pollingStation": { "type": "string" }
                }
              },
              "example": {
                "province": "Copperbelt",
                "ward": "Mayeni",
                "pollingStation": "Ndola Civic Center"
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated voter" },
          "400": { "description": "Validation error or invalid ID" },
          "401": { "description": "Authentication required" },
          "404": { "description": "Voter not found" }
        }
      },
      "delete": {
        "tags": ["Voters"],
        "summary": "Delete a voter by ID",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "6472c1f9b2ef2b7a6f8d3a54"
          }
        ],
        "responses": {
          "200": { "description": "Delete confirmation" },
          "400": { "description": "Invalid ID" },
          "401": { "description": "Authentication required" },
          "404": { "description": "Voter not found" }
        }
      }
    }
  }
}
